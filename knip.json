{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-lintignore"],
  "ignoreDependencies": [
    "@biomejs/biome",
    "next",
    "@commitlint/config-conventional"
  ],
  "workspaces": {
    ".": {
      "entry": ["commitlint.config.cjs"]
    },
    "apps/web": {
      "ignore": ["src/app/index.css", "onnxruntime-stub.js"]
    },
    "packages/typescript-config": {
      "ignore": ["*.json"]
    }
  }
}
