{
  "name": "@codeforge-v2/scraper",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "check-deps": "npx ncu --format group",
    "update-deps": "npx ncu -u --format group"
  },
  "dependencies": {
    "@codeforge-v2/database": "*",
    "@codeforge-v2/embeddings": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@codeforge-v2/typescript-config": "*",
    "typescript": "^5.9.3"
  }
}
