{
  "name": "@codeforge-v2/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "format": "biome check --write . --unsafe",
    "check-deps": "npx ncu --format group",
    "check-types": "tsc --noEmit",
    "update-deps": "npx ncu -u --format group",
    "build": "tsc",
    "start": "npx supabase start",
    "db-reset": "npx supabase db reset && npm run generate-api-types",
    "generate-api-types": "npx supabase gen types typescript --local > src/database.types.ts && npm run format && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codeforge-v2/typescript-config": "*",
    "typescript": "^5.9.3"
  }
}
