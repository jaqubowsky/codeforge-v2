{
  "name": "@codeforge-v2/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "check-deps": "pnpm dlx npm-check-updates --format group",
    "update-deps": "pnpm dlx npm-check-updates -u --format group",
    "start": "pnpm dlx supabase start",
    "db-reset": "pnpm dlx supabase db reset && pnpm generate-api-types",
    "generate-api-types": "pnpm dlx supabase gen types typescript --local > src/database.types.ts && cd ../.. && pnpm ultracite fix --unsafe && cd ./packages/database && pnpm build"
  },
  "dependencies": {
    "@supabase/postgrest-js": "^2.94.1",
    "@supabase/supabase-js": "^2.94.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@codeforge-v2/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
