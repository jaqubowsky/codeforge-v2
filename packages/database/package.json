{
  "name": "@codeforge-v2/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "format": "biome check --write . --unsafe",
    "check-deps": "ncu --format group",
    "check-types": "tsc --noEmit",
    "update-deps": "ncu -u --format group -u",
    "build": "tsc",
    "generate-api-types": "npx supabase gen types typescript --local > src/database.types.ts && npm run format"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.94.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@codeforge-v2/typescript-config": "*",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.9.3",
    "ultracite": "^7.1.4"
  }
}
